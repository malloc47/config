+    pub fn load_session(&mut self, session_id: &str) -> Result<()> {
+        let file_path = self
+            .index
+            .get_by_id(session_id)?
+            .ok_or_else(|| anyhow::anyhow!("Session not found: {}", session_id))?;
+        let session = parser::parse_session_file(&file_path)?;
+        let last_message_index = session.messages.len().saturating_sub(1);
+        let result = SearchResult {
+            session,
+            score: 0.0,
+            matched_message_index: last_message_index,
+            snippet: String::new(),
+            match_spans: Vec::new(),
+            match_fragment: String::new(),
+        };
+        self.results = vec![result];
+        self.selected = 0;
+        self.list_scroll = 0;
+        self.update_preview_scroll();
+        Ok(())
+    }
