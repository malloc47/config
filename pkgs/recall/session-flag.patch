+/// Launch the TUI deep-linked to a specific session id. Initial
+/// query is preserved (so `--session ID query terms` still works
+/// for in-session search), but the results list is pre-populated
+/// with just the target session so the preview pane opens on it
+/// immediately.
+fn run_tui_for_session(session_id: &str, initial_query: String) -> Result<()> {
+    let mut app = App::new(initial_query)?;
+    app.load_session(session_id)?;
+
+    let mut terminal = tui::init()?;
+    let result = run(&mut terminal, &mut app);
+    tui::restore()?;
+
+    if let Some(ref err) = app.index_error {
+        eprintln!("\nIndexing error:\n  {}\n", err);
+        eprintln!("Try: recall --reindex\n");
+    }
+
+    if let Some(session) = app.should_resume {
+        resume_session(&session)?;
+    } else if let Some(session_id) = app.should_copy {
+        copy_to_clipboard(&session_id)?;
+        println!("Copied session ID: {}", session_id);
+    }
+
+    result
+}
