@@ -34,6 +34,14 @@ arboard = "3"
 insta = "1.44.3"
 tempfile = "3"
 
+# Force ratatui's transitive `crossterm` dependency through the
+# `nornagon/color-query` fork that recall itself uses. Without this
+# redirect the dep graph contains two `crossterm 0.28.1` nodes (one
+# git, one registry), which `nix buildRustPackage`'s vendor step
+# can't disambiguate.
+[patch.crates-io]
+crossterm = { git = "https://github.com/nornagon/crossterm", branch = "nornagon/color-query" }
+
 [profile.release]
 lto = true
 codegen-units = 1
